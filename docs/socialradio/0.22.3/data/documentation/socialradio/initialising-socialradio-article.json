":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can tweak the SocialRadio UI and available feature set by changing flags on the config object. See "},{"type":"reference","identifier":"doc:\/\/org.cocoapods.SocialRadio\/documentation\/SocialRadio\/SocialRadioConfig","isActive":true},{"type":"text","text":"."}]},{"text":"TunedRestDelegate","anchor":"TunedRestDelegate","type":"heading","level":4},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"SocialRadio requires your applications OAuth2 access & refresh tokens in order to take over playback, provided via","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/org.cocoapods.SocialRadio\/documentation\/SocialRadio\/TunedRestDelegate\/tunedRestTokenExpired(deviceIdentifierForVendor:countryCode:tunedUserId:oldAccessToken:tokenType:completion:)","isActive":true,"type":"reference"}]}]}]},{"type":"codeListing","syntax":"swift","code":["public class MyTunedRestDelegate: NSObject, TunedRestDelegate {","    \/\/ ...","    public func tunedRestTokenExpired(deviceIdentifierForVendor: String, countryCode: String,","                                      tunedUserId: String?,","                                      oldAccessToken: String?, tokenType: String?,","                                      completion: @escaping (Error?, TunedAuthenticationResponse?, _ tunedUserId: String?) -> Void)","    {","        let response: TunedAuthenticationResponse = TunedAuthenticationResponse.init()","        response.access_token = myAccessToken","        response.token_type = myTokenType","        response.tuned_user_id = myTunedUserId","        completion(response, nil)","    }","    \/\/ ...","}"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"SocialRadio requires your client’s authenticated device, provided via","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/org.cocoapods.SocialRadio\/documentation\/SocialRadio\/