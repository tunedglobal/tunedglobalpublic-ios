{"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Essentials","anchor":"Essentials","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you want to fetch a list of currently available live broadcasts as paged request, you use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/org.cocoapods.SocialRadio\/documentation\/SocialRadio\/SocialRadio\/getLiveBroadcasts(limit:start:completion:)"},{"type":"text","text":" as shown below:"}]},{"code":["public class MyApplication {","    \/\/ ...","    func getBroadcasts() -> Void {","        let limit: Int = 10             \/\/ Get a total of 10 broadcasts","        let start: Int = 0              \/\/ Get the first broadcasts","        SocialRadio.instance.getLiveBroadcasts(limit: limit, start: start) { error, liveBroadcasts in","            \/\/ Present the broadcasts on your UI","            let myLiveBroadcasts = myLiveBroadcasts","            myLiveBroadcasts.add(liveBroadcasts)","            if(liveBroadcasts.size < limit) {","                \/\/ There are more broadcasts available!","                getNextLiveBroadcastsPage()","            }","        }","    }","    \/\/ ...","}"],"syntax":"swift","type":"codeListing"}]}],"sections":[],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/socialradio\/getting-available-broadcasts-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/socialradio\/getting-available-broadcasts-article"]}],"hierarchy":{"paths":[["doc:\/\/org.cocoapods.SocialRadio\/documentation\/SocialRadio"]]},"identifier":{"url":"doc:\/\/org.cocoapods.SocialRadio\/documentation\/SocialRadio\/Getting-available-broadcasts-article","interfaceLanguage":"swift"},"metadata":{"role":"article","modules":[{"name":"SocialRadio"}],"roleHeading":"Article","title":"Getting available broadcasts"},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"How to learn which bro