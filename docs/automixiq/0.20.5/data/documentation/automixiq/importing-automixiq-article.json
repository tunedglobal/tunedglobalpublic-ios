g AutomixIQ in your code","type":"heading"},{"inlineContent":[{"text":"To start using AutomixIQ, simply import the module:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Swift","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import AutomixIQ"],"type":"codeListing"},{"inlineContent":[{"text":"Objective-C","type":"text"}],"type":"paragraph"},{"syntax":"objective-c","code":["#import <AutomixIQ\/AutomixIQ-umbrella.h>"],"type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/automixiq\/importing-automixiq-article"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/automixiq\/importing-automixiq-article"]}],"sections":[],"references":{"doc://org.cocoapods.AutomixIQ/documentation/AutomixIQ":{"kind":"symbol","identifier":"doc:\/\/org.cocoapods.AutomixIQ\/documentation\/AutomixIQ","url":"\/documentation\/automixiq","abstract":[{"type":"text","text":"Enable smooth transitions between tracks for a seamlessly beat-matched experience within your iOS music application."}],"title":"AutomixIQ","type":"topic","role":"collection"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"path":"\/identifier\/interfaceLanguage","value":"occ","op":"replace"},{"path":"\/topicSections","value":null,"op":"add"},{"op":"add","value":null,"path":"\/seeAlsoSections"}]}]}