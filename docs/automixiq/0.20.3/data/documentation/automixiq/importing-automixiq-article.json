{"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Importing-the-library","text":"Importing the library"},{"inlineContent":[{"type":"text","text":"AutomixIQ can be imported into your project in one of two ways:"}],"type":"paragraph"},{"anchor":"Using-CocoaPods","level":3,"text":"Using CocoaPods:","type":"heading"},{"inlineContent":[{"type":"text","text":"Add the following lines to your podfile"}],"type":"paragraph"},{"code":["source 'https:\/\/github.com\/CocoaPods\/Specs.git'                                                 # Main Pods repository","source 'https:\/\/github.com\/tunedglobal\/tunedglobalpublic-ios.git'                               # Tuned Global's Pods repository","pod 'AutomixIQ'                                                                                 # Using AutomixIQ"],"syntax":"swift","type":"codeListing"},{"level":3,"type":"heading","anchor":"Manually-importing-the-AutomixIQ-framework","text":"Manually importing the AutomixIQ framework"},{"inlineContent":[{"text":"If you have been provided access to the AutomixIQ.xcframework file, you need to place it somewhere visible to your project, then tell XCode your project links against it.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"AutomixIQ depends on ‘nlohmann_json’ library, version 3.5.0, which is open source and can be procured from https:\/\/github.com\/nlohmann\/json.","type":"text"}]},{"level":2,"type":"heading","anchor":"Using-AutomixIQ-in-your-code","text":"Using AutomixIQ in your code"},{"inlineContent":[{"text":"To start using AutomixIQ, simply import the module:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Swift","type":"text"}],"type":"paragraph"},{"code":["import AutomixIQ"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Objective-C","type":"text"}],"type":"paragraph"},{"code":["#import <AutomixIQ\/AutomixIQ-umbrella.h>"],"syntax":"objective-c","type":"codeListing"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/org.cocoapods.AutomixIQ\/documentation\/AutomixIQ\/Importing-AutomixIQ-article"},"hierarchy":{"paths":[["doc:\/\/org.cocoapods.AutomixIQ\/documentation\/AutomixIQ"]]},"kind":"article","metadata":{"role":"article","modules":[{"name":"AutomixIQ"}],"roleHeading":"Article","title":"Importing AutomixIQ"},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/automixiq\/importing-automixiq-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/automixiq\/importing-automixiq-article"]}],"abstract":[{"type":"text","text":"Accessing the PacemakerAutomixIQ framework"}],"references":{"doc://org.cocoapods.AutomixIQ/documentation/AutomixIQ":{"abstract":[{"text":"Enable smooth transitions between tracks for a seamlessly beat-matched experience within your iOS music application.","type":"text"}],"title":"AutomixIQ","type":"topic","role":"collection","url":"\/documentation\/automixiq","identifier":"doc:\/\/org.cocoapods.AutomixIQ\/documentation\/AutomixIQ","kind":"symbol"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"op":"replace","path":"\/identifier\/interfaceLanguage","value":"occ"},{"value":null,"op":"add","path":"\/topicSections"},{"path":"\/seeAlsoSections","op":"add","value":null}]}]}